{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Performance Testing Configuration Schema",
  "type": "object",
  "required": ["server", "model", "benchmark", "test_matrix", "concurrency", "output"],
  "properties": {
    "server": {
      "type": "object",
      "required": ["host", "port"],
      "properties": {
        "host": {
          "type": "string",
          "description": "Server hostname or IP address"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Server port number"
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["name", "tokenizer_path"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Model name for benchmark"
        },
        "tokenizer_path": {
          "type": "string",
          "description": "Path to tokenizer directory"
        }
      }
    },
    "benchmark": {
      "type": "object",
      "required": ["dataset_name", "endpoint"],
      "properties": {
        "dataset_name": {
          "type": "string",
          "enum": ["random", "sharegpt", "sonnet"],
          "description": "Dataset name for benchmark"
        },
        "endpoint": {
          "type": "string",
          "description": "API endpoint path"
        },
        "ignore_eos": {
          "type": "boolean",
          "default": true
        },
        "trust_remote_code": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "test_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "input_len", "output_len"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_]+$",
            "description": "Test case identifier"
          },
          "input_len": {
            "type": "integer",
            "minimum": 1,
            "maximum": 131072,
            "description": "Random input token length"
          },
          "output_len": {
            "type": "integer",
            "minimum": 1,
            "maximum": 131072,
            "description": "Random output token length"
          },
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether this test case is enabled"
          }
        }
      }
    },
    "concurrency": {
      "type": "object",
      "required": ["levels", "final_num_prompts"],
      "properties": {
        "levels": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "description": "List of concurrency levels to test"
        },
        "final_num_prompts": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of prompts for final unlimited concurrency test"
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["dir", "format"],
      "properties": {
        "dir": {
          "type": "string",
          "description": "Output directory path"
        },
        "format": {
          "type": "string",
          "enum": ["json", "csv", "both"],
          "description": "Output file format"
        },
        "include_timestamp": {
          "type": "boolean",
          "default": true
        },
        "include_config_snapshot": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
